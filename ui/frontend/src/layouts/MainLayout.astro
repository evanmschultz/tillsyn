---
/**
 * MainLayout — Tillsyn's app-shell layout (Lane B D1 — 2-zone + status-footer).
 *
 * Reuses stil's canonical flex paradigm from
 * /Users/evanschultz/Documents/Code/hylla/stil/main/src/styles/global.css:45-52
 * — `.app` STAYS `display: flex` (NO grid). The 708-line vendored stil CSS
 * depends on flex push semantics (`flex-shrink: 0`, `transition: width`,
 * `body[data-sidebar-hidden] .app-sidebar { width: 0 }`); switching to grid
 * would break stil-canonical alignment for future stil-swift / iOS / Android
 * adapters.
 *
 * Shell shape (Lane B Round-2 Option A absorption):
 *   <body>            <-- outer flex column
 *     <div class="app">                  <-- stil-canonical flex row
 *       <aside class="app-sidebar">      <-- left sidebar (slot)
 *       <main class="app-main">
 *         <header class="app-topbar">    <-- brand-only Topbar (HV-2 default)
 *         <slot/>                        <-- KanbanBoard / page content
 *     <footer class="app-status-footer"> <-- SIBLING of .app (sticky-bottom)
 *     <nav class="app-bottom-tabs">      <-- mobile only (CSS-gated ≤640)
 *
 * StatusFooter sits OUTSIDE `.app` because `.app { overflow: hidden }` would
 * clip a sticky child. Outer `<body>` flex column gives sticky-bottom + no
 * `position: fixed` hack.
 *
 * Imports:
 *   - vendored design tokens + reset + global styles from src/styles/.
 *   - Inter (sans) + JetBrains Mono via @fontsource (Wails webview offline).
 *   - NavRail import + DOM REMOVED (Lane B D1) — `.app-rail` CSS stays
 *     dormant in global.css for potential future revival.
 */

import "../styles/global.css";
import "../styles/components.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/600.css";

import Topbar from "../components/Topbar.astro";
import BottomTabs from "../components/BottomTabs.astro";

interface Props {
  title?: string;
}

const { title = "Tillsyn" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="app">
      <aside class="app-sidebar">
        <slot name="sidebar" />
      </aside>

      <main class="app-main">
        <header class="app-topbar">
          <Topbar title={title} />
        </header>
        <div class="app-main-body">
          <div class="app-content">
            <slot />
          </div>
        </div>
      </main>
    </div>

    <footer class="app-status-footer">
      <slot name="statusFooter" />
    </footer>

    <BottomTabs />
  </body>
</html>
