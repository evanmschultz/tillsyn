---
/**
 * MainLayout — Tillsyn's app-shell layout.
 *
 * Mirrors the stil Playground layout (drop_fe_3):
 *   - Imports vendored design tokens + reset + global styles from
 *     src/styles/ (refreshed from stil/main/src/styles/ at the current
 *     snapshot).
 *   - Imports the two self-hosted font families actually referenced by the
 *     stil token stack (Inter for --font-sans, JetBrains Mono for
 *     --font-mono) via @fontsource so we don't depend on a CDN reachable
 *     from inside the Wails webview. Iosevka and Fira Code were dropped in
 *     the FE3 cleanup pass — neither was referenced by any token or
 *     selector after the stil vendor (~5.75 MB of dist bloat avoided).
 *   - Renders the L-frame shell: NavRail + Topbar + main content slot.
 */

import "../styles/global.css";
import "../styles/components.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/600.css";

import NavRail from "../components/NavRail.astro";
import Topbar from "../components/Topbar.astro";

interface Props {
  title?: string;
}

const { title = "Tillsyn" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="app">
      <div class="app-rail">
        <NavRail />
      </div>

      <div class="app-main">
        <Topbar title={title} />
        <div class="app-main-body">
          <main class="app-content">
            <slot />
          </main>
        </div>
      </div>
    </div>
  </body>
</html>
