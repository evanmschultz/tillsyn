---
/**
 * Topbar — brand-only chrome strip at the top of `.app-main` (Lane B D1).
 *
 * HV-2 orch default: brand-only. The earlier subtitle ("Planning and
 * coordination") + disabled settings icon were trimmed per Lane B Round-2
 * — coordination context now lives in the StatusFooter below `.app`, and
 * Settings will route through BottomTabs (mobile) + a future sidebar pivot.
 *
 * Mirrors the stil Topbar pattern (same --bg-chrome, NavRail-aligned
 * --topbar-height) but reduced to brand + (future) action affordances. Held
 * inside `<header class="app-topbar">` which lives inside `<main class="app-main">`
 * — stil canonical pattern preserved.
 *
 * NOTE: not a `// MIGRATION TARGET: @hylla/stil-solid` consumer — Astro
 * server component, not a Solid island. `migration-markers.test.ts` gates
 * only .tsx/.ts files under src/components/.
 */

interface Props {
  title?: string;
}

const { title = "Tillsyn" } = Astro.props;
---

<div class="topbar" aria-label="App topbar">
  <div class="topbar-left">
    <span class="topbar-brand">{title}</span>
  </div>
</div>

<style>
  .topbar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: 0 var(--space-4);
    height: var(--topbar-height);
    flex-shrink: 0;
    background: var(--bg-chrome);
    position: relative;
    overflow: hidden;
    transition: height var(--duration-base) var(--ease-out);
  }

  .topbar-left {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .topbar-brand {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
  }
</style>
