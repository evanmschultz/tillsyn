# macOS
.DS_Store

# Go build outputs
/till
/till.exe
bin/
# /dist/ scoped to repo root — goreleaser output target. Path-scoped (vs bare
# `dist/`) so it does not also match ui/frontend/dist/ at depth, which has its
# own contents-exclude + .gitkeep re-include rule below.
/dist/
coverage.out

# Tillsyn runtime state — ignore everything under .tillsyn/ except the
# self-host cascade template (Drop 4c.5 F.2.3). Tillsyn dogfoods its own
# template ergonomics by tracking <repo_root>/.tillsyn/template.toml in git;
# spawns/, log/, tillsyn.db, etc. are runtime state and stay ignored.
# Pattern note: re-inclusion under an excluded directory requires excluding
# the directory's CONTENTS (`.tillsyn/*`) rather than the directory itself
# (`.tillsyn/`); the latter blocks every re-include rule per gitignore docs.
.tillsyn/*
!.tillsyn/template.toml
!.tillsyn/agents/
!.tillsyn/agents/**/*.md
!.tillsyn/bindings.json
.artifacts/
.tmp/

# Editor / IDE cruft
.vscode/
.idea/
*.swp
*.swo

# Playwright MCP scratch — screenshots + console logs from orch-side visual
# verification. Useful artifacts for one session; not committed.
.playwright-mcp/
*~

# Agent / tool state — track project-level configuration (.claude/agents/*.md +
# .claude/settings.json) so subagent personas + tool allowlists travel with the
# repo. Per-machine variants (.local.json + sessions/) stay ignored.
.claude/*.local.json
.claude/sessions/
.claude/agent-runs/
.codex/*.local.json
.codex/sessions/
.nvimlog

# Wails build outputs and generated bindings (Drop 4c.6.1 W6.D1; relocated under ui/ at drop_fe_1_bootstrap D1.1)
ui/build/
ui/frontend/node_modules/
# ui/frontend/dist/ — ignore generated contents but track a placeholder so the
# Go //go:embed all:frontend/dist directive in ui/main.go compiles even when
# the FE hasn't been built (e.g. fresh CI checkout). Pattern follows the same
# contents-exclude + re-include shape used for .tillsyn/ above.
ui/frontend/dist/*
!ui/frontend/dist/.gitkeep
ui/frontend/.astro/
ui/frontend/wailsjs/
ui/frontend/package.json.md5

# Secrets — belt-and-suspenders
.env
.env.local
*.pem
*.key
agents.local.toml
